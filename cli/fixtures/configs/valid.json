{
  "stack": "ts",
  "thresholds": {
    "changedLineCoverage": 80,
    "minTests": 1
  },
  "visual": {
    "routes": ["/", "/login"],
    "breakpoints": [375, 768, 1280],
    "baselineDir": "visual/baselines",
    "baseURL": "http://localhost:3000",
    "minScore": 90,
    "maxDiffRatio": 0,
    "tolerance": 2,
    "blocking": true
  },
  "wired": ["db", "auth"],
  "rules": {
    "enabled": true,
    "disabled": ["no-dev-script-in-layout"],
    "warnOnly": ["no-mock-in-prod-path"]
  }
}
