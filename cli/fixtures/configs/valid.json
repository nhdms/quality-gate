{
  "stack": "ts",
  "thresholds": {
    "changedLineCoverage": 80,
    "minTests": 1
  },
  "visual": {
    "routes": ["/", "/login"],
    "breakpoints": [375, 1280],
    "baselineDir": "visual/baselines"
  },
  "wired": ["db", "auth"],
  "rules": {
    "enabled": true,
    "disabled": ["no-dev-script-in-layout"],
    "warnOnly": ["no-mock-in-prod-path"]
  }
}
