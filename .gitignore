# Node
node_modules/

# Gate run artifacts (generated by the lanes; never committed).
# Anchored to the repo root so test fixtures under cli/fixtures/coverage/ stay tracked.
/coverage/
*.tap
*.gate.diff
# Visual oracle run artifacts (captures + manifest). Approved BASELINES are
# committed by the consuming repo under visual.baselineDir — these are not.
/.visual/
# Wired-not-mock (T3) capture artifacts. Produced in-run by wiredSetup.command;
# committing them would let a hand-crafted capture fake a green.
/wired-captures/

# agent-orchestrator / local agent tooling (not part of the project)
.ao/
.claude/
.omc/
